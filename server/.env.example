# Copy to `server/.env` — never commit real keys.

# --- Chroma (local persistent store) ---
CHROMA_PATH=./data/chroma
VECTOR_BACKEND=chroma

# --- Ollama embeddings (pull model: ollama pull nomic-embed-text) ---
OLLAMA_BASE_URL=http://127.0.0.1:11434
EMB_MODEL=nomic-embed-text

# --- Chunking (eFront PDFs: aim ~800–1200 / overlap 150–250; metadata adds page/slide + module + section hint) ---
# CHUNK_SIZE=1000
# CHUNK_OVERLAP=200

# --- LangSmith (optional tracing) ---
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# --- Server ---
# HOST=127.0.0.1
# PORT=8000
