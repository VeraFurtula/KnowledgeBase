EFRONT_AZURE_USER=
EFRONT_AZURE_PASSWORD=
# Optional: override entry URL (default is .../Login.aspx — use that, not Login.ashx bookmark)
# EFRONT_AZURE_LOGIN_URL=http://frt21jvhxunbw7f7zo5xq.westeurope.cloudapp.azure.com:8081/Login.aspx
# Optional: force headless Chromium locally (default is a visible window for npm run test:e2e:efront)
# PW_HEADLESS=1
# Optional: record WebM video of the run (large); step PNGs are always written to test-results/efront-login-walkthrough/
# PW_RECORD_VIDEO=1
# Optional: slow down each browser action (milliseconds, max 2500) — easier to watch in UI or headed mode
# PW_SLOW_MO=400
